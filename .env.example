# This is an example of your .env file format for local dev and Vercel production.
# Production should use DATABASE_URL from a Vercel-managed Neon Postgres project.
# POSTGRES_URL is kept only as a legacy local fallback.
DATABASE_URL=postgresql://***
POSTGRES_URL=
CREEM_API_KEY=creem_test_***
CREEM_WEBHOOK_SECRET=whsec_***
CREEM_TEST_MODE=1
CREEM_PRODUCT_ONE_TIME_ID=prod_***
CREEM_PRODUCT_MONTHLY_ID=prod_***
CREEM_PRODUCT_ANNUAL_ID=prod_***
FREEMIUS_PRODUCT_ID=
FREEMIUS_API_KEY=
FREEMIUS_SECRET_KEY=
FREEMIUS_PUBLIC_KEY=
FREEMIUS_WEBHOOK_SECRET=
FREEMIUS_PRICING_ONE_TIME_ID=
FREEMIUS_PRICING_MONTHLY_ID=
FREEMIUS_PRICING_ANNUAL_ID=
BILLING_PROVIDER_ACTIVE=freemius
PAYMENT_PROVIDER_DEFAULT=freemius
BILLING_PROVIDER_ALLOW_CREEM_FALLBACK=1
FEATURE_CREEM_UI=0
FEATURE_CREEM_ROUTES=1
BASE_URL=http://localhost:3000
AUTH_SECRET=***
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# FamilyEducation product settings
OPENAI_API_KEY=
OPENAI_MODEL_VISION=
MATHPIX_APP_ID=
MATHPIX_APP_KEY=
GOOGLE_APPLICATION_CREDENTIALS=
SUPPORT_EMAIL=admin@pathnook.com
DATA_RETENTION_DAYS=30
DEFAULT_LOCALE=en-US
DEFAULT_COUNTRY=US
DEFAULT_TIMEZONE=America/Los_Angeles
FAMILY_EDU_DEMO_MODE=0
FAMILY_EDU_DEMO_AUTO_AUTH=0
FILE_STORAGE_BACKEND=blob
BLOB_READ_WRITE_TOKEN=
NODE_USE_ENV_PROXY=1

# Optional Vercel CLI targeting
VERCEL_ORG_ID=team_***
VERCEL_PROJECT_ID=prj_***
